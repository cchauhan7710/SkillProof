  "scripts": {
    "dev": "nodemon src/server.js",
    "python": "cd HeartOFProject/resume-skill-extractor && .\\.venv\\Scripts\\python.exe -m uvicorn api:app --host 0.0.0.0 --port 8001 --reload",
