# ── Server Configuration ─────────────────────────────────────────────
PORT=8000
NODE_ENV=production

# ── Database Configuration ───────────────────────────────────────────
# MongoDB connection string (Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/database_name

# ── Deployment Links ────────────────────────────────────────────────
# For multiple origins, use comma-separated values: https://app1.vercel.app,https://app2.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app
BACKEND_URL=https://your-backend.onrender.com

# ── Authentication Secrets ──────────────────────────────────────────
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY=10d

# ── External Services ───────────────────────────────────────────────
# Cloudinary (Image/File Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_CLOUD_API=your_cloudinary_key
CLOUDINARY_CLOUD_SECRET=your_cloudinary_secret

# Gemini AI (Resume Parsing)
GEMINI_API_KEY=your_gemini_api_key

# Groq AI (Advanced Analysis)
GROQ_API_KEY=your_groq_api_key

# GitHub PAT (Repository Analysis)
GITHUB_PAT=your_github_personal_access_token

# ── Internal Microservices ──────────────────────────────────────────
# Python NLP Service URL (Default is localhost:8001 within the same Render service)
PYTHON_NLP_URL=http://localhost:8001

